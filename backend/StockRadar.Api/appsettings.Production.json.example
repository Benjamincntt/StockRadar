{
  "Cache": {
    "Enabled": true,
    "StockListSeconds": 300,
    "MarketIndexSeconds": 30,
    "SmartMoneyContextSeconds": 300,
    "EngineTrustSeconds": 30
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=StockRadarDb;User Id=YOUR_SQL_USER;Password=YOUR_SQL_PASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Issuer": "StockRadar",
    "Audience": "StockRadar.Client",
    "Secret": "CHANGE_ME_32_CHARS_MINIMUM_PRODUCTION_KEY!",
    "ExpiryMinutes": 1440
  },
  "MarketData": {
    "SyncApiKey": "CHANGE_ME_SYNC_API_KEY",
    "AutoSyncEnabled": true,
    "SyncIntervalSeconds": 60
  },
  "MarketJobs": {
    "History": {
      "Enabled": false,
      "RunOnStartup": false
    },
    "DailySession": {
      "Enabled": true
    },
    "DailyAnalysis": {
      "Enabled": true
    }
  },
  "IntradayScanner": {
    "Enabled": true,
    "IntervalSeconds": 120
  },
  "OpportunityMonitor": {
    "Enabled": true,
    "IntervalSeconds": 60
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://127.0.0.1:5281"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "TelegramNotify": {
    "Enabled": true,
    "BotToken": "YOUR_BOT_TOKEN_FROM_BOTFATHER",
    "ChatId": "YOUR_TELEGRAM_CHAT_ID"
  },
  "HyperparameterTuning": {
    "Enabled": true,
    "RepoRoot": "/var/www/StockRadar",
    "PythonPath": "/var/www/StockRadar/.venv-tune/bin/python",
    "ScriptPath": "/var/www/StockRadar/scripts/tune-optuna.py",
    "OutputPath": "/var/www/StockRadar/Data/weekly-tuning-result.json",
    "Trials": 50,
    "Days": 60,
    "TimeoutPerTrialSeconds": 300,
    "ProcessTimeoutMinutes": 45
  }
}
