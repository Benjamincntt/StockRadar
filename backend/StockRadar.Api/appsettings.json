{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5280"
      }
    },
    "Limits": {
      "KeepAliveTimeout": "00:15:00",
      "RequestHeadersTimeout": "00:15:00"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=StockRadarDb;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Cache": {
    "Enabled": true,
    "StockListSeconds": 60,
    "MarketIndexSeconds": 30
  },
  "Jwt": {
    "Issuer": "StockRadar",
    "Audience": "StockRadar.Client",
    "Secret": "dev-secret-change-in-production-min-32-chars!!",
    "ExpiryMinutes": 1440
  },
  "MarketData": {
    "SyncApiKey": "dev-sync-key-change-me",
    "AutoSyncEnabled": false
  },
  "MarketJobs": {
    "BypassApiCache": true,
    "History": {
      "Enabled": false,
      "RunOnStartup": false,
      "Universe": "Groups",
      "Exchange": "HOSE",
      "Groups": ["HOSE", "HNX", "UPCOM"],
      "StartDate": "2000-01-01",
      "DelayBetweenSymbolsMs": 300,
      "NightDelayBetweenSymbolsMs": 1500,
      "MinAvgDailyVolume": 100000,
      "VolumeLookbackSessions": 30,
      "ScreeningLookbackDays": 450,
      "ExcludeIpoWithinDays": 365,
      "BypassCache": true
    },
    "DailySession": {
      "Enabled": true,
      "Exchange": "HOSE",
      "Hour": 15,
      "Minute": 0,
      "BatchSize": 40
    },
    "DailyAnalysis": {
      "Enabled": true,
      "DelayAfterSessionMinutes": 2,
      "MinScore": 60,
      "MaxResults": 30,
      "ManualAnalysisCooldownMinutes": 15
    }
  },
  "SmartMoney": {
    "MinHistoryDays": 21,
    "MinAvgDailyVolume": 800000,
    "BreakoutMinVolumeRatio": 1.5,
    "TopSectorCount": 5,
    "MinPassScore": 60,
    "MaxGainInBasePercent": 5,
    "MaStack": {
      "Enabled": true,
      "MinSessionsForMa50": 50,
      "MinSessionsForFullStack": 200
    },
    "SectorRankWeights": {
      "RelativeStrength": 0.35,
      "TotalVolume": 0.25,
      "CapProxy": 0.25,
      "StockCount": 0.15
    }
  },
  "PriceRunupFilter": {
    "ConsolidationMaxRangePercent": 15,
    "ConsolidationMinSessions": 5,
    "MaxScanSessions": 120,
    "MaxGainFromBasePercent": 10,
    "MaxCloseDriftPercent": 8,
    "MaxBandSeparationPercent": 5
  },
  "IntradayScanner": {
    "Enabled": false
  },
  "OpportunityMonitor": {
    "Enabled": true,
    "IntervalSeconds": 60,
    "MinForeignFlowDelta": 50000,
    "MinProprietaryDelta": 30000,
    "MinHangVolume": 150000,
    "MinHangVolumeDelta": 50000,
    "MinPutThroughDelta": 10000,
    "BatchSize": 40,
    "ForceRunOutsideHours": true
  },
  "ZaloNotify": {
    "Enabled": false,
    "PhoneNumber": "0968992857",
    "WebhookUrl": "",
    "CooldownMinutes": 30
  }
}
